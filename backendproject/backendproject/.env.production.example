# PRODUCTION ENVIRONMENT
NODE_ENV=production

# Server
PORT=5000
HOST=0.0.0.0

# Database (Use PostgreSQL for production)
DATABASE_URL=postgresql://user:password@db-host:5432/technexus_prod

# JWT (MUST use strong secret - at least 32 characters)
JWT_SECRET=generate-random-32-char-key-using-crypto.randomBytes
JWT_EXPIRE=24h

# Admin Credentials (Database-driven in production)
# Do NOT store in environment - use database with hashed passwords

# CORS (Set to your production domain)
CORS_ORIGIN=https://technexus.com

# Payment Gateways (Live keys)
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx

# Rate Limiting (Strict for production)
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=50

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/technexus/api.log
